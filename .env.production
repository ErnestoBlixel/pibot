# === PIBOT — PRODUCCION (EasyPanel) ===

# -- LLM --
OPENROUTER_API_KEY=sk-or-v1-TU_CLAVE_REAL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# -- Voz --
OPENAI_API_KEY=sk-TU_CLAVE_OPENAI

# -- Base de datos (nombres Docker internos) --
DATABASE_URL=postgresql+asyncpg://pibot:TU_PASSWORD_SEGURA@postgres:5432/pibot
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=TU_PASSWORD_SEGURA

# -- Telegram --
TELEGRAM_BOT_TOKEN=TU_BOT_TOKEN
TELEGRAM_CHAT_ID_ERNESTO=TU_CHAT_ID
TELEGRAM_CHAT_ID_MARTA=CHAT_ID_MARTA

# -- n8n --
N8N_BASE_URL=http://n8n:5678
N8N_WEBHOOK_SECRET=GENERA_UN_SECRET_SEGURO
N8N_ENCRYPTION_KEY=GENERA_CLAVE_ENCRIPTACION

# -- Seguridad --
AGENT_AUTH_TOKEN=GENERA_UN_TOKEN_SEGURO
JWT_SECRET=GENERA_UN_JWT_SECRET_SEGURO

# -- Entorno --
ENVIRONMENT=production
LOG_LEVEL=INFO
