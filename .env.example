# -- LLM --
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# -- Voz --
OPENAI_API_KEY=sk-...
STT_PROVIDER=openai
TTS_PROVIDER=openai
TTS_VOICE=alloy

# -- Base de datos --
DATABASE_URL=postgresql+asyncpg://pibot:PASSWORD@localhost:5432/pibot
REDIS_URL=redis://localhost:6379/0

# -- Telegram --
TELEGRAM_BOT_TOKEN=7123456789:AAF...
TELEGRAM_CHAT_ID_ERNESTO=123456789
TELEGRAM_CHAT_ID_MARTA=987654321

# -- n8n --
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=secret_seguro

# -- Seguridad API --
AGENT_AUTH_TOKEN=token_seguro
JWT_SECRET=jwt_seguro

# -- Entorno --
ENVIRONMENT=production
LOG_LEVEL=INFO
